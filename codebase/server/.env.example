# --- Serveur ---
PORT=4000
# Origines autorisées (CORS), séparées par des virgules — front local + domaine de prod.
CORS_ORIGIN=http://localhost:3000,https://paralirana.com,https://www.paralirana.com

# --- MongoDB Atlas ---
# Atlas > Database > Connect > Drivers. Autorisez l'accès réseau (0.0.0.0/0) pour Render.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/paralirana?retryWrites=true&w=majority

# --- Authentification ---
# Chaîne longue et aléatoire (ex: openssl rand -base64 48).
JWT_SECRET=remplacez-par-une-longue-chaine-aleatoire

# --- Cloudinary (Dashboard > Account Details). Laisser vide pour coller des URLs d'images. ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Compte administrateur (utilisé une seule fois par `npm run seed`) ---
ADMIN_EMAIL=admin@paralirana.com
ADMIN_PASSWORD=choisissez-un-mot-de-passe-fort
