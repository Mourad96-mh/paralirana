# --- Frontend (static export → Hostinger) ---
# The dynamic backend (DB, orders, admin, uploads) lives in ./server (Express → Render).
# This app only needs these public/build vars.

# Public WhatsApp number for ordering (international format, no +, no spaces)
# Example for Morocco: 212612345678
NEXT_PUBLIC_WHATSAPP=2126XXXXXXXX

# Canonical site URL (used for sitemap + metadata)
NEXT_PUBLIC_SITE_URL=https://paralirana.com

# URL of the Express API (Render). Local dev: http://localhost:4000
NEXT_PUBLIC_API_URL=https://paralirana-api.onrender.com
# Same API, read at BUILD time by scripts/sync-content.mjs to bake the catalog
# snapshot (lib/catalog.data.json) into the static HTML for SEO.
CONTENT_API_URL=https://paralirana-api.onrender.com
