# Public WhatsApp number for ordering (international format, no +, no spaces)
# Example for Morocco: 212612345678
NEXT_PUBLIC_WHATSAPP=2126XXXXXXXX

# Canonical site URL (used for sitemap + metadata)
NEXT_PUBLIC_SITE_URL=https://parador.ma

# --- Database (MongoDB Atlas) ---
# Create a free cluster at https://cloud.mongodb.com and paste the connection string.
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/parador?retryWrites=true&w=majority

# --- Admin auth ---
# Secret used to sign the admin session JWT. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret
# Seed credentials — used ONCE by `npm run seed` to create the admin account.
ADMIN_EMAIL=admin@parador.ma
ADMIN_PASSWORD=change-me

# --- Cloudinary (product image uploads) ---
# From your Cloudinary dashboard (https://cloudinary.com). Leave blank to paste image URLs manually.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
